# TikTok AI Streamer - Variables de Entorno
# Copia este archivo a .env y configura tus valores

# === TikTok ===
# Nombre de usuario del streamer de TikTok (sin @)
TIKTOK_USERNAME=demo_user

# === AI (Groq) ===
# API Key en: https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_aqui
# Modelo recomendado: llama-3.1-8b-instant o llama3-70b-8192
GROQ_MODEL=llama-3.1-8b-instant

# === TTS ===
TTS_ENABLED=False
TTS_COOLDOWN=5
TTS_ENGINE=kokoro
TTS_VOICE=im_nicola
TTS_VOICE_BLEND=
TTS_SPEED=1.0
TTS_LANG=es
TTS_PITCH=0
TTS_VOLUME=1.0

# === AI ===
AI_ENABLED=False

# === Kokoro (modelos ONNX) ===
# Descargar de: https://github.com/thewh1teagle/kokoro-onnx/releases
KOKORO_MODEL=models/kokoro-v1.0.fp16.onnx
KOKORO_MODEL_FP32=models/kokoro-v1.0.onnx
KOKORO_VOICES=models/voices-v1.0.bin

# === Piper ===
PIPER_MODEL_PATH=models/piper/model.onnx

# === Servidores ===
OVERLAY_PORT=5000
PANEL_PORT=5001
HOST=0.0.0.0
